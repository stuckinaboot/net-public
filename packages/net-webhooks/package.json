{
  "name": "@net-protocol/webhooks",
  "version": "0.1.0",
  "description": "Push notification layer for Net Protocol — subscribe to topics/senders and get webhook callbacks on new messages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "net-webhooks": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/cli.ts",
    "start": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@net-protocol/core": "file:../net-core",
    "commander": "^12.1.0",
    "viem": "^2.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^1.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stuckinaboot/net-public.git",
    "directory": "packages/net-webhooks"
  },
  "keywords": [
    "net",
    "protocol",
    "webhooks",
    "push",
    "notifications",
    "agents",
    "blockchain"
  ]
}
